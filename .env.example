# Free LLM Gateway — 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# ✅ pollinations 和 g4f 无需任何 Key，开箱即用

# ──────────────────────────────────────────
# ✅ 无需 Key（默认启用）
# ──────────────────────────────────────────
# Pollinations.ai — 合法免费服务，无需注册
#   模型: openai / mistral / llama / deepseek / qwen / gemini
#   文档: https://pollinations.ai

# gpt4free (g4f) — 逆向工程，支持数十个 provider
#   模型: gpt-4o / claude-3 / gemini 等
#   仓库: https://github.com/xtekky/gpt4free
#   注意: 稳定性不保证，仅供学习研究

# ──────────────────────────────────────────
# 🔑 需要 Key（有 Key 则优先使用，更稳定）
# ──────────────────────────────────────────

# Gemini (Google AI Studio)
# 免费额度: 1500 次/天, 15 次/分钟，无需绑卡
# 申请地址: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq
# 免费额度: 14400 次/天, 30 次/分钟，无需绑卡
# 申请地址: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (免费模型后缀 :free)
# 免费额度: 20 次/分钟 (免费模型)，无需绑卡
# 申请地址: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cloudflare Workers AI
# 免费额度: 10000 neurons/天
# 申请地址: https://dash.cloudflare.com → AI → Workers AI
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ──────────────────────────────────────────
# 可选配置
# ──────────────────────────────────────────
# Provider 优先顺序 (有 Key 的排前面更稳定，无 Key 的兜底)
PROVIDER_ORDER=gemini,groq,openrouter,cloudflare,pollinations,g4f

# 网关监听地址和端口
HOST=0.0.0.0
PORT=8000
